#include "resource.h"
#include <windows.h>

// Main application icon. Listed first so it becomes the default app icon.
IDI_APPICON ICON "icon.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 0,1,0,0
 PRODUCTVERSION 0,1,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "PocketDisplay"
            VALUE "FileDescription", "PocketDisplay"
            VALUE "FileVersion", "0.1.0.0"
            VALUE "InternalName", "PocketDisplay"
            VALUE "LegalCopyright", "Copyright (C) PocketDisplay"
            VALUE "OriginalFilename", "PocketDisplay.exe"
            VALUE "ProductName", "PocketDisplay"
            VALUE "ProductVersion", "0.1.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
